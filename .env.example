# Stripe API keys — obtain from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Optional: webhook signing secret from Developers → Webhooks
STRIPE_WEBHOOK_SECRET=

# Connected account identity / pricing defaults
CONNECTED_ACCOUNT_COUNTRY=US
STRIPE_CURRENCY=usd

# Redirect URLs used by Account Links and Checkout
STRIPE_RETURN_URL=http://localhost:4242/return
STRIPE_REFRESH_URL=http://localhost:4242/refresh
STRIPE_SUCCESS_URL=http://localhost:4242/success

# Optional override for where seller Stripe IDs are persisted
# PAYMENTS_STORE_PATH=/path/to/payments-store.json
