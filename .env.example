# Obtain keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional webhook signing secret from `stripe listen`
STRIPE_WEBHOOK_SECRET=whsec_...

# Blueprint environment variables
STRIPE_CURRENCY=usd
STRIPE_CONNECTED_ACCOUNT_COUNTRY=us

# Optional redirect URLs (defaults match the Stripe blueprint)
# STRIPE_SUCCESS_URL=
# STRIPE_REFRESH_URL=
# STRIPE_RETURN_URL=

# Webhook server port (default: 4242)
# STRIPE_WEBHOOK_PORT=4242
