# Stripe API keys — obtain from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret — obtain from https://dashboard.stripe.com/webhooks
# (or `stripe listen --print-secret` when using the Stripe CLI)
STRIPE_WEBHOOK_SECRET=

# Connected account defaults (Accounts v2 blueprint)
CONNECTED_ACCOUNT_COUNTRY=us
CURRENCY=usd

# Optional redirects for onboarding / checkout
STRIPE_RETURN_URL=http://localhost:4242/onboarding/return
STRIPE_REFRESH_URL=http://localhost:4242/onboarding/refresh
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:4242/checkout/success

# Optional path for the local JSON store of Stripe resource ids
# CUBIC_STRIPE_STORE=.cubic-stripe.json
