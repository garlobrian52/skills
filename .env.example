# Obtain these from the Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret from the Dashboard or `stripe listen --print-secret`
STRIPE_WEBHOOK_SECRET=

# Connected account defaults (Accounts v2)
CONNECTED_ACCOUNT_COUNTRY=us
CURRENCY=usd

# Onboarding redirects for create-account-link
STRIPE_RETURN_URL=https://example.com/onboarding/return
STRIPE_REFRESH_URL=https://example.com/onboarding/refresh

# Checkout success redirect for create-checkout-session
STRIPE_CHECKOUT_SUCCESS_URL=https://example.com/checkout/success

# Optional override for the local merchant / Stripe ID store
# STRIPE_DATA_PATH=/path/to/stripe-store.json
