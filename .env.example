# Stripe keys — obtain from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Optional webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# Connected account country (ISO 3166-1 alpha-2) and currency for Checkout / Prices
CONNECTED_ACCOUNT_COUNTRY=US
CURRENCY=usd

# Base URL used for Account Link return/refresh and Checkout success URLs
BASE_URL=http://localhost:4242

# Optional override for where seller/subscription Stripe IDs are persisted
# STRIPE_STORE_PATH=.cubic-stripe-store.json
